<%- include('../partials/header') %>
<main>
  <h1><%= title %></h1>

  <form action="/organizations/<%= organization.organization_id %>" method="POST">
    <div class="form-group">
      <label for="name">Organization Name</label>
      <input type="text" id="name" name="name" required maxlength="150" value="<%= organization.name %>" />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" required maxlength="500"><%= organization.description %></textarea>
    </div>

    <div class="form-group">
      <label for="contactEmail">Contact Email</label>
      <input type="email" id="contactEmail" name="contactEmail" required value="<%= organization.contact_email %>" />
    </div>

    <button type="submit">Update Organization</button>
  </form>
</main>
<%- include('../partials/footer') %>
