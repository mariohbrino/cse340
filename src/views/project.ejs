<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
  <h2><%= project.title %></h2>
  <p><%= project.description %></p>
  <p>Location: <%= project.location %></p>
  <p>
    Date: <% let projectDate = new Date(project.date); %> <%= projectDate.toLocaleDateString("en-US", { year: "numeric",
    month: "long", day: "numeric" }) %>
  </p>
  <p>Organization: <a href="/organizations/<%= project.organization_id %>"><%= project.organization_name %></a></p>
  <ul>
    <% if (categories && categories.length > 0) { %> <% categories.forEach(category => { %>
    <li>
      <a href="/categories/<%= category.category_id %>"><%= category.name %></a>
    </li>
    <% }); %>
    <% } else { %>
    <li>No categories available</li>
    <% } %>
  </ul>
</main>
<%- include('partials/footer') %>
