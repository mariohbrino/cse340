<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>

  <div class="detail-container">
    <div class="detail-header">
      <h2><%= project.title %></h2>
    </div>

    <div class="detail-section">
      <h3>Description</h3>
      <div class="description"><%= project.description %></div>
    </div>

    <div class="detail-section">
      <h3>Project Details</h3>
      <div class="metadata">
        <div class="metadata-item">
          <span class="metadata-label">Location:</span>
          <span class="metadata-value"><%= project.location %></span>
        </div>

        <div class="metadata-item">
          <span class="metadata-label">Date:</span>
          <span class="metadata-value">
            <% let projectDate = new Date(project.date); %> <%= projectDate.toLocaleDateString("en-US", { year:
            "numeric", month: "long", day: "numeric" }) %>
          </span>
        </div>

        <div class="metadata-item">
          <span class="metadata-label">Organization:</span>
          <span class="metadata-value">
            <a href="/organizations/<%= project.organization_id %>"><%= project.organization_name %></a>
          </span>
        </div>
      </div>
    </div>

    <div class="detail-section">
      <h3>Categories</h3>

      <% if (categories && categories.length > 0) { %>
      <div class="category-tags">
        <% categories.forEach(category => { %>
        <a href="/categories/<%= category.category_id %>" class="category-tag"> <%= category.name %> </a>
        <% }); %>
      </div>
      <% } else { %>
      <div class="empty-state">No categories assigned to this project.</div>
      <% } %>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
