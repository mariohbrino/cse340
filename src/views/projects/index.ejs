<%- include('../partials/header') %>
<main>
  <h1><%= title %></h1>

  <div class="projects-list">
    <h2>Upcoming Service Projects</h2>

    <p>
      <a class="new-project-button" href="/new-project">Add a New Service Project</a>
    </p>

    <% projects.forEach(project => { %>
    <% let projectDate = new Date(project.date); %>
    <div class="projects-list-item">
      <div class="projects-list-date">
        <%= projectDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) %>
      </div>
      <div class="projects-list-title">
        <a href="/projects/<%= project.project_id %>"><%= project.title %></a>
      </div>
      <div class="projects-list-org">
        <a href="/organizations/<%= project.organization_id %>"><%= project.organization_name %></a>
      </div>
    </div>
    <% }) %>
  </div>
</main>
<%- include('../partials/footer') %>
